# Universal Admin Platform — Environment Variables

NODE_ENV=development
PORT=4100

# Database (separate PostgreSQL instance for UAP)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uap?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-min-32-characters-long!!
JWT_ISSUER=uap
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d

# Stripe (optional — billing features)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (optional — email notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG...
SMTP_FROM=noreply@sigops.io

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=debug
